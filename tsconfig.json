{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@menuflow/shared": [
        "packages/shared/src"
      ],
      "@menuflow/shared/*": [
        "packages/shared/src/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build"
  ]
}
